# ============================================================
# Environment Variables
# ============================================================
# Contains SSH credentials, database configuration,
# Docker settings, and other sensitive values.
# Never commit secrets to source control.
.env

# ============================================================
# Kubernetes Secrets
# ============================================================
# Contains database passwords, SSH credentials,
# and other sensitive Kubernetes Secret values.
#
# These files are created manually in the target
# Kubernetes environment and should never be
# committed to source control.
#
# Examples:
# - diagnostics-secret (Opaque Secret)
# - diagnostics-tls (TLS Secret)
#
# Apply manually:
# kubectl apply -f k8s/secret.yaml
# kubectl apply -f k8s/tls-secret.yaml
k8s/secret.yaml
k8s/tls-secret.yaml

# ============================================================
# TLS Certificates
# ============================================================
# Self-signed certificates used for local
# Ingress HTTPS testing.
#
# Generated using OpenSSL:
# openssl req -x509 ...
#
# Production environments typically use:
# - Corporate CA
# - Let's Encrypt
# - cert-manager
#
# Never commit private keys.
certs/

# ============================================================
# Python Virtual Environment
# ============================================================
# Local development dependencies.
# Recreated using requirements.txt.
venv/

# ============================================================
# Python Cache Files
# ============================================================
__pycache__/
*.pyc
*.pyo

# ============================================================
# Pytest
# ============================================================
.pytest_cache/

# ============================================================
# Coverage Reports
# ============================================================
.coverage
htmlcov/

# ============================================================
# IDE Files
# ============================================================
.vscode/
.idea/

# ============================================================
# macOS Files
# ============================================================
.DS_Store

# ============================================================
# Application Logs
# ============================================================
*.log
